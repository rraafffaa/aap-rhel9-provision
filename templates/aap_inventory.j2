# AAP 2.6 Containerized Installer Inventory
# Generated by AAP on Azure provisioning playbook

[automationcontroller]
{{ azure_vm_name }} ansible_host={{ aap_private_ip }} ansible_connection=local

{% if aap_install_hub %}
[automationhub]
{{ azure_vm_name }} ansible_host={{ aap_private_ip }} ansible_connection=local
{% endif %}

{% if aap_install_eda %}
[automationeda]
{{ azure_vm_name }} ansible_host={{ aap_private_ip }} ansible_connection=local
{% endif %}

[database]
{{ azure_vm_name }} ansible_host={{ aap_private_ip }} ansible_connection=local

[all:vars]
# Connection
ansible_user={{ azure_vm_admin_user }}
ansible_become=true

# Red Hat Registry credentials (for pulling AAP container images)
registry_username={{ rhsm_username }}
registry_password={{ rhsm_password }}

# AAP Controller
controller_admin_password={{ aap_admin_password }}
controller_pg_password={{ aap_pg_password }}

{% if aap_install_hub %}
# Automation Hub
hub_admin_password={{ aap_admin_password }}
hub_pg_password={{ aap_pg_password }}
{% endif %}

{% if aap_install_eda %}
# Event-Driven Ansible
eda_admin_password={{ aap_admin_password }}
eda_pg_password={{ aap_pg_password }}
{% endif %}

# PostgreSQL
postgresql_admin_password={{ aap_pg_password }}

# Bundled installer uses podman
bundle_install=true
